# CrediFi backend — environment template.
#
# Copy to .env and fill in the values. NEVER commit .env.
#
# DATABASE_URL is the Neon Postgres connection string for the CrediFi read
# cache / history log. Mayur owns this; do not generate or hardcode it
# in this repo. Get it from the Neon dashboard → Project → Connection Details
# (use the "Pooled" connection string, with `?sslmode=require`).
#
# Example placeholder — replace USER, PASSWORD, HOST, DBNAME:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DATABASE_URL=
