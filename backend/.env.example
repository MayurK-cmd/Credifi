# CrediFi backend — environment template.
#
# Copy to .env and fill in the values. NEVER commit .env.
#
# DATABASE_URL is the Neon Postgres connection string for the CrediFi read
# cache / history log. Mayur owns this; do not generate or hardcode it
# in this repo. Get it from the Neon dashboard → Project → Connection Details
# (use the "Pooled" connection string, with `?sslmode=require`).
#
# Example placeholder — replace USER, PASSWORD, HOST, DBNAME:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DATABASE_URL=

# HSK Chain JSON-RPC URL. Testnet for dev, mainnet for production.
# Testnet default example (replace with the real one from hashfans.io docs):
HSK_RPC_URL=https://testnet-rpc.hashfans.io

# Chain ID. Testnet is 133; mainnet is currently a placeholder (9001)
# until confirmed against the live RPC.
CHAIN_ID=133

# Deployed CrediFi contract addresses (from contracts/deployments/<network>.json).
# Testnet values shown; mainnet will differ.
ORACLE_ADDRESS=0x6345Ec7861cDCf8798F5D40348d91Cdbe077544B
POOL_ADDRESS=0x0bFeE39682e4a5CA057A33838d06Ca7b43bF42Cc

# Backend relayer private key. The derived address MUST equal `oracle.signer`
# on the deployed Oracle. Hot key — never commit.
RELAYER_PRIVATE_KEY=

# HTTP server port.
PORT=3001

# Signature time-to-live in seconds. The signed score expires after this
# window. Default one hour.
SCORE_TTL_SECONDS=3600
