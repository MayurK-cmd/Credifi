# CrediFi frontend — environment variables.
# Copy this file to `.env.local` and fill in the values for the network you want.
# Vite exposes any var prefixed with VITE_ to the client bundle.

# Backend REST API base URL (no trailing slash). The frontend hits /api/* off this.
VITE_API_URL=http://localhost:3001

# HSK Chain testnet contract addresses — already deployed, see
# contracts/deployments/hskTestnet.json. Swap to mainnet addresses for prod.
VITE_ORACLE_ADDRESS=0x6345Ec7861cDCf8798F5D40348d91Cdbe077544B
VITE_POOL_ADDRESS=0x0bFeE39682e4a5CA057A33838d06Ca7b43bF42Cc

# HSK Chain JSON-RPC endpoint used for read-only calls (score lookups,
# accrual queries, pool stats refresh). Same URL the backend uses.
VITE_HSK_RPC_URL=https://testnet.hsk.xyz

# 133 = HSK Chain testnet. Flip to whatever mainnet uses for prod.
VITE_CHAIN_ID=133

# WalletConnect Cloud projectId (https://cloud.walletconnect.com). Required by
# RainbowKit to enable the WalletConnect v2 transport. In dev, a placeholder
# works — RainbowKit warns in the console but the injected (MetaMask) connector
# is unaffected. Get a real one for production.
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id-here
